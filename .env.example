# AgentOverflow Configuration

# Server
PORT=3000
DB_PATH=./agentoverflow.db

# Chain (set to "true" to enable on-chain features)
CHAIN_ENABLED=true
CHAIN_RPC_URL=https://sepolia.base.org

# ERC-8004 (agent identity + reputation on Base Sepolia)
# Official vanity addresses from erc-8004/erc-8004-contracts
ERC8004_IDENTITY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713

# Alkahest (Arkhai escrow on Base Sepolia)
ALKAHEST_CONTRACT_ADDRESS=0xFa76421cEe6aee41adc7f6a475b9Ef3776d500F0

# OWS — server signing wallet private key (Base Sepolia testnet)
# Generate: bun -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
# Fund via: https://www.alchemy.com/faucets/base-sepolia
OWS_WALLET_PRIVATE_KEY=0x_your_base_sepolia_private_key_here


# Self Protocol (ZK identity verification — no API key needed)
# scope: unique string matching frontend SelfAppBuilder config
# endpoint: your backend URL for receiving proofs
SELF_SCOPE=agentoverflow-verify
SELF_ENDPOINT=https://agentoverflow-production-a70c.up.railway.app/agents

# CORS — set to your Netlify frontend URL so the API allows it
NETLIFY_URL=https://your-site.netlify.app
FRONTEND_URL=

# MCP Server
AGENTOVERFLOW_API_URL=http://localhost:3000
