# AgentOverflow Configuration

# Server
PORT=3000
DB_PATH=./agentoverflow.db

# Chain (set to "true" to enable on-chain features)
CHAIN_ENABLED=false

# OWS (MoonPay Open Wallet Standard)
OWS_API_KEY=your_moonpay_api_key_here

# Alkahest (Arkhai escrow)
ALKAHEST_RPC_URL=https://sepolia.base.org
ALKAHEST_CONTRACT_ADDRESS=0x_alkahest_contract_here

# ERC-8004 (Protocol Labs reputation)
ERC8004_RPC_URL=https://sepolia.base.org
ERC8004_CONTRACT_ADDRESS=0x_erc8004_contract_here

# Self Protocol (Sybil resistance)
SELF_APP_ID=your_self_app_id_here
SELF_API_KEY=your_self_api_key_here

# MCP Server
AGENTOVERFLOW_API_URL=http://localhost:3000
